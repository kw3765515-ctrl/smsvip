# ─── Loading Animation ────────────────────────────────────────────────────────
loading_spinner() {
    local msg="$1"
    local pid=$2
    local spin='⣾⣽⣻⢿⡿⣟⣯⣷'
    local i=0
    
    while kill -0 $pid 2>/dev/null; do
        i=$(( (i+1) % 8 ))
        printf "\r${CYN}  ${spin:$i:1} ${msg}${NC}"
        sleep 0.1
    done
    printf "\r${LGRN}  ✓ ${msg} เสร็จสิ้น${NC}                    \n"
}

# ─── Check Dependencies ───────────────────────────────────────────────────────
check_deps() {
    echo -e "${CYN}  ⚙️  กำลังตรวจสอบระบบ...${NC}"
    
    if ! command -v curl &> /dev/null; then
        echo -e "${BRED}  ✗ ไม่พบ curl กรุณาติดตั้งก่อน${NC}"
        exit 1
    fi
    
    sleep 0.5
    echo -e "${LGRN}  ✓ ระบบพร้อมใช้งาน${NC}"
}

# ─── Check API ────────────────────────────────────────────────────────────────
check_api() {
    echo ""
    echo -e "${BYLW}  🔌 กำลังเชื่อมต่อ API...${NC}"
    
    local response
    response=$(curl -s -o /dev/null -w "%{http_code}" "${API_URL}/health" --max-time 5 2>/dev/null)
    
    if [ "$response" == "200" ]; then
        echo -e "${LGRN}  ✓ เชื่อมต่อ API สำเร็จ${NC}"
        return 0
    else
        echo -e "${BRED}  ✗ ไม่สามารถเชื่อมต่อ API ได้ (HTTP ${response})${NC}"
        echo ""
        echo -e "${YLW}  💡 กรุณาตรวจสอบ:${NC}"
        echo -e "     - อินเทอร์เน็ตเชื่อมต่ออยู่หรือไม่"
        echo -e "     - API กำลังทำงานอยู่หรือไม่"
        exit 1
    fi
}

