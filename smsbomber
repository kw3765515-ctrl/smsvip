# ─── Progress Bar ─────────────────────────────────────────────────────────────
show_progress() {
    local current=$1
    local total=$2
    local success=$3
    local failed=$4
    local width=50
    local progress=$(( (current * width) / total ))
    local percentage=$(( (current * 100) / total ))
    
    printf "\r  ${CYN}▶${NC} ["
    for ((i=0; i<width; i++)); do
        if [ $i -lt $progress ]; then
            printf "${LGRN}█${NC}"
        else
            printf "${GRY}░${NC}"
        fi
    done
    printf "] ${BWHT}%3d%%${NC} | ${LGRN}✓ %d${NC} | ${LRED}✗ %d${NC}" "$percentage" "$success" "$failed"
}

# ─── Global counters ──────────────────────────────────────────────────────────
declare -g SUCCESS_COUNT=0
declare -g FAIL_COUNT=0

# ─── Send SMS via API ─────────────────────────────────────────────────────────
send_sms_api() {
    local phone=$1
    local count=$2
    SUCCESS_COUNT=0
    FAIL_COUNT=0
    
    echo ""
    print_line "=" "$MGN"
    echo -e "${BMGN}  🚀 เริ่มยิง SMS...${NC}"
    print_line "=" "$MGN"
    echo ""
    
    for ((i=1; i<=count; i++)); do
        show_progress $i $count $SUCCESS_COUNT $FAIL_COUNT
        
        response=$(curl -s -X POST "${API_URL}/send" \
            -H "Content-Type: application/json" \
            -d "{\"phone\":\"$phone\",\"count\":1}" \
            --max-time 15 2>/dev/null)
        
        if echo "$response" | grep -q '"success":true'; then
            ((SUCCESS_COUNT++))
        else
            ((FAIL_COUNT++))
        fi
        
        sleep 0.3
    done
    
    echo ""
    echo ""
}

# ─── Show Results ─────────────────────────────────────────────────────────────
show_results() {
    local phone=$1
    local count=$2
    local success=$3
    local failed=$4
    
    print_line "=" "$MGN"
    echo -e "${BMGN}  📊 สรุปผลการดำเนินการ${NC}"
    print_line "=" "$MGN"
    echo ""
    echo -e "  ${WHT}╔══════════════════════════════════════════════════════════╗${NC}"
    printf "  ${WHT}║${NC}  📱 เป้าหมาย:     ${BWHT}%-40s${WHT}║${NC}\n" "$phone"
    printf "  ${WHT}║${NC}  📨 จำนวนทั้งหมด: ${BWHT}%-3d ครั้ง%-33s${WHT}║${NC}\n" "$count" ""
    printf "  ${WHT}║${NC}  ${LGRN}✓ สำเร็จ:${NC}        ${LGRN}%-3d ครั้ง%-33s${WHT}║${NC}\n" "$success" ""
    printf "  ${WHT}║${NC}  ${LRED}✗ ล้มเหลว:${NC}       ${LRED}%-3d ครั้ง%-33s${WHT}║${NC}\n" "$failed" ""
    echo -e "  ${WHT}╚══════════════════════════════════════════════════════════╝${NC}"
    echo ""
    
    if [ "${success:-0}" -eq "$count" ]; then
        echo -e "  ${LGRN}🎉 ยิงสำเร็จทั้งหมด!${NC}"
    elif [ "${success:-0}" -gt 0 ]; then
        echo -e "  ${YLW}⚡ ยิงสำเร็จบางส่วน${NC}"
    else
        echo -e "  ${BRED}💥 ยิงไม่สำเร็จเลย${NC}"
    fi
}

# ─── Quick Mode ───────────────────────────────────────────────────────────────
quick_mode() {
    local phone=$1
    local count=$2
    
    check_deps
    check_api
    
    # Validate
    if [[ ! "$phone" =~ ^[0-9]{10}$ ]]; then
        echo -e "${BRED}✗ เบอร์โทรไม่ถูกต้อง! ต้องเป็นตัวเลข 10 หลัก${NC}"
        exit 1
    fi
    
    if [[ ! "$count" =~ ^[0-9]+$ ]] || [ "$count" -lt 1 ] || [ "$count" -gt 100 ]; then
        echo -e "${BRED}✗ จำนวนไม่ถูกต้อง! ต้องอยู่ระหว่าง 1-100${NC}"
        exit 1
    fi
    
    show_banner
    
    echo -e "  ${CYN}📱 เป้าหมาย:${NC} ${BWHT}$phone${NC}"
    echo -e "  ${CYN}🔢 จำนวน:${NC} ${BWHT}$count${NC} ครั้ง"
    echo ""
    
    send_sms_api "$phone" "$count"
    show_results "$phone" "$count" $SUCCESS_COUNT $FAIL_COUNT
}

