# ─── Functions ────────────────────────────────────────────────────────────────
clear_screen() {
    clear 2>/dev/null || printf '\033[2J\033[H'
}

print_center() {
    local text="$1"
    local color="${2:-$NC}"
    local width=79
    local padding=$(( (width - ${#text}) / 2 ))
    printf "%${padding}s${color}%s${NC}%${padding}s\n" "" "$text" ""
}

print_line() {
    local char="${1:-$HLINE}"
    local color="${2:-$MGN}"
    printf "${color}%s${NC}\n" "$(printf '%0.s'"$char" $(seq 1 79))"
}

print_box_top() {
    echo -e "${MGN}${TL}$(printf '%0.s'"$HLINE" $(seq 1 77))${TR}${NC}"
}

print_box_bottom() {
    echo -e "${MGN}${BL}$(printf '%0.s'"$HLINE" $(seq 1 77))${BR}${NC}"
}

print_box_line() {
    local text="$1"
    local color="${2:-$WHT}"
    local padding=$(( (77 - ${#text}) / 2 ))
    local extra=$(( (77 - ${#text}) % 2 ))
    printf "${MGN}${VLINE}${NC}%${padding}s${color}%s${NC}%${padding}s" "" "$text" ""
    [ $extra -eq 1 ] && printf " "
    echo -e "${MGN}${VLINE}${NC}"
}

